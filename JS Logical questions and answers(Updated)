// 18. Anagram
const Anagram = (str1, str2) => {
    const str1Dum = str1.toLowerCase().split('').sort().join('')
    const str2Dum = str2.toLowerCase().split('').sort().join('')
    if(str1Dum === str2Dum){
        return true
    }else{
        return false
    }
}

